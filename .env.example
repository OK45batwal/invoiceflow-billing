FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# Render production should use the FIREBASE_* values above.
# Local development can alternatively use Google ADC on your own machine.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=InvoiceFlow Pro <your-email@gmail.com>
DEFAULT_OTP_ROLE=admin
OTP_APP_NAME=InvoiceFlow Pro
NODE_ENV=production
DATA_DIR=/var/data
STORAGE_DRIVER=json
