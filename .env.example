# ─── Firebase (required in production) ───────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# Local development can alternatively use Google ADC on your own machine.

# ─── Email delivery via Brevo HTTP API (required in production) ───────────────
# Sign up at https://app.brevo.com — free tier: 300 emails/day, 9,000/month.
# No custom domain needed — just verify your sender email address in Brevo.
#
# Steps:
#   1. Create account at brevo.com
#   2. Go to Settings → Senders & IPs → Add a Sender (verify your email)
#   3. Go to Settings → API Keys → Generate a new API key
#
# RENDER NOTE: Do NOT use SMTP variables. Render free-tier blocks SMTP ports
# (25, 465, 587). Brevo's REST API uses HTTPS (port 443) — no SMTP needed.
BREVO_API_KEY=your-brevo-api-key-here
BREVO_FROM_EMAIL=youremail@gmail.com
BREVO_FROM_NAME=InvoiceFlow Pro

# ─── OTP settings ─────────────────────────────────────────────────────────────
DEFAULT_OTP_ROLE=admin
OTP_APP_NAME=InvoiceFlow Pro

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
DATA_DIR=/var/data
STORAGE_DRIVER=json
